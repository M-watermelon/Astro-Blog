---
interface Props {
	title: string;
	date: string;
	body: string;
	href: string;
}

const { href, title, date, body } = Astro.props;

import pin from "../images/pin2.png";

---

<li class="link-card">
	<img style="padding-left:20px; height:50px; transform: scaleX(-1); " src={pin.src}>
	<a href={href}>
		<h2>
			{title}
			<span style="color: var(--purple);">&rarr; </span>
		</h2>
		
		<h4>
			{date}
		</h4>
		<p>
			{body}
		</p>
	</a>
	
</li>
<style>
	.link-card {
		list-style: none;
		box-shadow: rgba(0, 0, 0, 0.5) 5px 5px 5px 5px;
		width:auto;
		margin:40px;
		margin-left: 20px;
		padding-left: 0px;
    	padding: 20px;
		border-radius: 20px;
	}
	
	.link-card > a {
		color: var(--roseWhite);
		width: 100%;
		text-decoration: none;
		line-height: 1.4;
		padding: calc(2.5rem - 10px);
		border-radius: 8px;
		transition: 0.3s;
	}
	.link-card > a:hover {
		color: var(--tropical-indigo);
		transform:scale(40px);
	}


	h2 {
		text-decoration: none;
		margin-left: 0px;
		margin-bottom: 30px;
	}
	h4 {
		text-decoration: none;
		font-size: 12px;
		color:var(--purple);
		margin-left: 0px;
		margin-bottom: 30px;
	}
	p {
		font-size:20px;
		font-weight: 100px;
		margin-bottom: 0;
	}

</style>
